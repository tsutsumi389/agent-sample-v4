# LLM プロバイダ: ollama (ローカル, 既定) / openai (ChatGPT・OpenAI互換API)
APP_LLM_PROVIDER=ollama
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent
APP_OLLAMA_BASE_URL=http://localhost:11434
APP_CHAT_MODEL=gpt-oss
APP_MEMORY_MODEL=qwen3
APP_EMBED_MODEL=nomic-embed-text
APP_NUM_CTX=32768
APP_REASONING_EFFORT=medium
# OpenAI / ChatGPT (APP_LLM_PROVIDER=openai のとき使用)。判断系は Structured Outputs を使う。
# APP_OPENAI_API_KEY=sk-...
# APP_OPENAI_CHAT_MODEL=gpt-4o-mini
# APP_OPENAI_CONTROL_MODEL=gpt-4o-mini
# OpenAI互換エンドポイント (Azure OpenAI 等) を使う場合のみ:
# APP_OPENAI_BASE_URL=https://api.openai.com/v1
APP_CORS_ORIGINS=["http://localhost:5173"]
APP_MCP_CONFIG_PATH=mcp_servers.json
APP_REFLECTION_DELAY_SECONDS=30
# MCP サーバ用のシークレット例 (mcp_servers.json の ${VAR} 置換に使用)
# GITHUB_TOKEN=
